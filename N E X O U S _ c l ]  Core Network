sharkMult     = input.float(2.0, "Shark Multiplier (×)",   minval=1.1, maxval=5.0, step=0.1, group="Shark Volume Engine",
  tooltip="Volume spike threshold relative to average. Higher = fewer but stronger shark signals.")
avgVolLength  = input.int(20,    "Avg Volume Period",       minval=5,   maxval=50,  group="Shark Volume Engine")

// ── Sessions ──────────────────────────────────────────────────────────
showSessions  = input.bool(true, "Show Session Ranges",                             group="Sessions")

showNY        = input.bool(true, "NYSE / NASDAQ   16:30 – 23:00",                  group="Sessions")
nySess        = input.session("1630-2300:1234567","NYSE/NASDAQ Time",               group="Sessions")
nyCol         = input.color(#f97316,"NYSE Color",                                   group="Sessions", inline="ny")

showLondon    = input.bool(true, "London Stock Exchange   10:00 – 18:30",           group="Sessions")
londonSess    = input.session("1000-1830:1234567","London Time",                    group="Sessions")
londonCol     = input.color(#3b82f6,"London Color",                                 group="Sessions", inline="ldn")

showJapan     = input.bool(true, "Japan Exchange Group   03:00 – 09:00",            group="Sessions")
japanSess     = input.session("0300-0900:1234567","Japan Time",                     group="Sessions")
japanCol      = input.color(#f43f5e,"Japan Color",                                  group="Sessions", inline="jpn")

showHK        = input.bool(true, "Hong Kong Stock Exchange   04:30 – 11:00",        group="Sessions")
hkSess        = input.session("0430-1100:1234567","Hong Kong Time",                 group="Sessions")
