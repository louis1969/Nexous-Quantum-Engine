    table.cell(dash, 0, 34, "SMC  SIGNAL", text_color=colTextLight, text_size=dashTextSize, bgcolor=sigBg)
    table.cell(dash, 1, 34, sigTxt,         text_color=sigClr,      text_size=dashTextSize, bgcolor=sigBg)

    string cmbTxt = isShark and delta > 0 ? "🟢  BUY" : isShark and delta < 0 ? "🔴  SELL" : "⏳  WAIT"
    color  cmbBg  = isShark and delta > 0 ? color.new(color.green, 75) :
      isShark and delta < 0 ? color.new(color.red, 75) : darkBg
    table.cell(dash, 0, 35, "COMBINED  SIGNAL", text_color=colTextLight, text_size=dashTextSize, bgcolor=cmbBg)
    table.cell(dash, 1, 35, cmbTxt, text_color=color.white, text_size=dashTextSize, bgcolor=cmbBg)

    // ── TIMEFRAME + FOOTER ────────────────────────────────────────────────
    table.cell(dash, 0, 36, "TF   " + timeframe.period,
      text_color=colNeutralLight, text_size=size.tiny, bgcolor=darkBg)
    table.cell(dash, 1, 36, "© NEXOUS_cl  v1.0",
      text_color=color.new(colNeutral, 40), text_size=size.tiny,
      bgcolor=darkBg, text_halign=text.align_center)

