showShang     = input.bool(true, "Shanghai Stock Exchange   04:30 – 10:00",         group="Sessions")
shangSess     = input.session("0430-1000:1234567","Shanghai Time",                  group="Sessions")
shangCol      = input.color(#a855f7,"Shanghai Color",                               group="Sessions", inline="shg")

// ── Dashboard ─────────────────────────────────────────────────────────
showDash      = input.bool(true,"Show Dashboard",                                   group="Dashboard")
dashPos       = input.string("Top Right","Position",
  options=["Top Left","Top Right","Bottom Left","Bottom Right"],                     group="Dashboard")
