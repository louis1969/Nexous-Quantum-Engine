//@version=6
indicator("NEXOUS v8.0 - QUANTUM ORDER FLOW", overlay = true, max_labels_count = 500, max_boxes_count = 500, max_bars_back = 1000)

//#region ————— NEXOUS OFFICIAL PALETTE
color NEX_CYAN   = #1de9b6 // Bullish / Primary
color NEX_BLUE   = #00b0ff // Neutral
color NEX_RED    = #ff1744 // Bearish
color NEX_ORANGE = #ff9100 // Whale / Institutional
color NEX_GREEN  = #00c853 // Institutional Momentum
color BG_DASH    = color.new(#080c16, 15)
//#endregion

//#region ————— INPUTS
string grp_flow = "Order Flow Engine"
string i_lower_tf    = input.string("1", "Order Flow Granularity (Min)", options = ["1", "5", "15", "30", "60"], group = grp_flow)
float i_sig_factor   = input.float(1.5, "Significant Order Factor", minval = 1.1, group = grp_flow)
float i_inst_factor  = input.float(5.0, "Institutional Order Factor", minval = 3.0, group = grp_flow)

string grp_quant = "Whale & Quantum Logic"
int i_adx_len        = input.int(14, "ADX Period", group = grp_quant)
int i_quantum_thresh = input.int(30, "Quantum Exhaustion (ADX)", group = grp_quant)
//#endregion

//#region ————— MODULE 1: API SENTIMENT BRIDGE
// Proxy for Market Mood using BTC/USD (Global Sentiment)
float sentiment_val = request.security("INDEX:BTCUSD", "D", close)
float sentiment_sma = ta.sma(sentiment_val, 10)
float sentiment_score = ((sentiment_val - sentiment_sma) / math.max(syminfo.mintick, sentiment_sma)) * 100 + 50

string label_mood = sentiment_score > 60 ? "MOONING 🚀" : sentiment_score < 40 ? "PANIC 😱" : "NEUTRAL 😐"
color s_col       = sentiment_score > 60 ? NEX_CYAN : sentiment_score < 40 ? NEX_RED : NEX_BLUE
//#endregion

//#region ————— MODULE 5: WHALE & ORDER FLOW ENGINE
// Whale Activity Detection (Nexous Rule: 2.5x SMA 50)
float vol_sma_50 = ta.sma(volume, 50)
bool is_whale_active = volume > vol_sma_50 * 2.5

// Lower TF Volume Analysis for Microstructure
float[] lower_tf_vol = request.security_lower_tf(syminfo.tickerid, i_lower_tf, volume)

var float[] rolling_sizes = array.new_float(0)
if array.size(lower_tf_vol) > 0
    for i = 0 to array.size(lower_tf_vol) - 1
        float v = array.get(lower_tf_vol, i)
        array.unshift(rolling_sizes, v)
        if array.size(rolling_sizes) > 100
            array.pop(rolling_sizes)

float avg_size = array.size(rolling_sizes) > 0 ? array.avg(rolling_sizes) : 1.0

// Institutional Tier Classification
string tier_text = "Standard"
color f_col      = NEX_BLUE

if array.size(lower_tf_vol) > 0
    float last_v = array.get(lower_tf_vol, 0)
    if last_v >= avg_size * i_inst_factor
        tier_text := "INSTITUTIONAL 🐋"
        f_col     := NEX_ORANGE
    else if last_v >= avg_size * (i_inst_factor * 0.7)
        tier_text := "MASSIVE 🔥"
        f_col     := NEX_GREEN
    else if last_v >= avg_size * i_sig_factor
        tier_text := "SIGNIFICANT 💎"
        f_col     := NEX_CYAN
//#endregion

//#region ————— MODULE 22: QUANTUM DASHBOARD
var table nexous_tab = table.new(position.top_right, 2, 5, bgcolor = BG_DASH, border_width = 1, border_color = color.new(NEX_BLUE, 50), frame_width = 1)

if barstate.islast
    // Cleanup & Initialization
    table.cell(nexous_tab, 0, 0, "NEXOUS v8.0 PRO", text_color = NEX_CYAN, text_size = size.small)
    table.merge_cells(nexous_tab, 0, 0, 1, 0)
    
    // Rows
    table.cell(nexous_tab, 0, 1, "Market Mood", text_color = color.white, text_size = size.tiny)
    table.cell(nexous_tab, 1, 1, label_mood, bgcolor = color.new(s_col, 80), text_color = s_col, text_size = size.tiny)

    table.cell(nexous_tab, 0, 2, "Order Flow", text_color = color.white, text_size = size.tiny)
    table.cell(nexous_tab, 1, 2, tier_text, bgcolor = color.new(f_col, 80), text_color = f_col, text_size = size.tiny)

    table.cell(nexous_tab, 0, 3, "Whale Activity", text_color = color.white, text_size = size.tiny)
    table.cell(nexous_tab, 1, 3, is_whale_active ? "ACTIVE 🐋" : "QUIET", text_color = is_whale_active ? NEX_ORANGE : NEX_BLUE, text_size = size.tiny)
    
    [_, _, adx_val] = ta.dmi(i_adx_len, i_adx_len)
    bool is_quantum = adx_val < i_quantum_thresh
    table.cell(nexous_tab, 0, 4, "Quantum State", text_color = color.white, text_size = size.tiny)
    table.cell(nexous_tab, 1, 4, is_quantum ? "EXHAUSTION" : "TRENDING", text_color = is_quantum ? NEX_ORANGE : NEX_CYAN, text_size = size.tiny)
//#endregion

//#region ————— SIGNALS & VISUALS
// Institutional Alert Logic (Non-Repainting)
bool alert_long  = tier_text == "INSTITUTIONAL 🐋" and close > open
bool alert_short = tier_text == "INSTITUTIONAL 🐋" and close < open

// Fix: Explicit named arguments for plotshape to prevent positional compiler errors
plotshape(alert_long, 
     title     = "Whale Buy Signal", 
     style     = shape.labelup, 
     location  = location.belowbar, 
     color     = NEX_CYAN, 
     text      = "WHALE BUY", 
     textcolor = color.black, 
     size      = size.small)

plotshape(alert_short, 
     title     = "Whale Sell Signal", 
     style     = shape.labeldown, 
     location  = location.abovebar, 
     color     = NEX_RED, 
     text      = "WHALE SELL", 
     textcolor = color.white, 
     size      = size.small)

// Whale Bar Highlighting
barcolor(is_whale_active ? NEX_ORANGE : na)
//#endregion
